# Database Configuration (defaults match docker-compose.yml)
POSTGRES_USER=gem_scramble
POSTGRES_PASSWORD=password
POSTGRES_DB=gem_scramble
DATABASE_URL="postgresql://gem_scramble:password@localhost:5432/gem_scramble"

# Redis Configuration
REDIS_URL="redis://localhost:6379"

# Firebase Configuration (required when AUTH_MODE=firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-service-account@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project-id.iam.gserviceaccount.com

# Server Configuration
PORT=8080
NODE_ENV=development

# Auth mode: "dev" (trust userId from request) or "firebase" (verify ID token).
# Set to "dev" on Railway for username-only testing. Defaults to "firebase" when
# NODE_ENV=production unless AUTH_MODE is set explicitly.
AUTH_MODE=dev

# Optional extra CORS origins (comma-separated). Firebase Hosting origins are
# already baked into the server; only add more if you host the web app elsewhere.
CORS_ORIGINS=

# Max requests per IP per minute (default 120).
RATE_LIMIT_MAX=120

# PgAdmin Configuration (docker-compose only)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_admin_password
